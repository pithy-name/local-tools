# screenshot-section-extractor — example config.
# Copy to `.env` and edit for your form.  `.env` is gitignored (your real values).
#
# Heading/stop values are REGEXES matched against OCR text that has been
# lowercased and stripped of punctuation — so write them lowercase. Inline
# `#` comments are allowed on unquoted values; quote a value if it must contain
# spaces-then-# or you want to preserve a trailing comment character.

# Name of the person the assessment is about (used only in output headings).
SUBJECT_NAME=Jordan Rivera

# Which files to process in the image directory (IMAGE_DIR below).
INPUT_GLOB=*.png

# IMAGE_DIR is NOT a .env key — it's the first command-line argument to
# extract_section.py (e.g. `python3 extract_section.py IMAGE_DIR out.md`),
# defaulting to "." if omitted. It's a CLI arg rather than a .env key because
# it changes per invocation (which folder of screenshots you're batching this
# run), unlike the other settings here, which are stable per form. Its
# location doesn't matter — point it at any directory, relative or absolute,
# containing your screenshots; INPUT_GLOB above just filters which files in
# that directory get picked up.

# OCR upscale for the tight section pass (higher = sharper, slower).
OCR_SCALE=3.0

# --- Self column -------------------------------------------------------------
# The heading that STARTS the section you want, and the one that ENDS it.
SELF_HEADING=things .{0,4}do well
SELF_STOP=how could .{0,4}improve
# Crop band + which line left-edges (xmin) count as "self" text (normalized 0-1).
SELF_X0=0.28
SELF_X1=0.64
SELF_XMIN_LO=0.315
SELF_XMIN_HI=0.60

# --- Manager column ----------------------------------------------------------
# The (?:\w+ )+ wildcard matches the subject's name inside the heading whether it
# is one word or several: "things Jordan does well" or "things Jordan Rivera does well".
# (SUBJECT_NAME above is output-only; it is NOT used for matching.)
MANAGER_HEADING=things (?:\w+ )+does well
MANAGER_STOP=how could (?:\w+ )+improve
MANAGER_X0=0.595
MANAGER_X1=0.99
MANAGER_XMIN=0.605

# =============================================================================
# ALTERNATE CALIBRATION PROFILE: profile_2col_v2
# A second, wider two-column layout seen on a differently-styled assessment
# form. NOT read by extract_section.py by default (the script only reads the
# unprefixed SELF_*/MANAGER_* keys above) — this block is reference values for
# a form matching this geometry. To use it, replace the active SELF_*/MANAGER_*
# values above with the PROFILE_2COL_V2_* values below (INDENT is a code
# constant in extract_section.py, not a .env key — edit there if you adopt
# this profile as default).
#
# XMIN_LO/XMIN_HI/XMIN are estimated from the same offset pattern as the
# default profile (not independently OCR-verified against this layout) —
# re-tune against real screenshots before relying on this profile.
# =============================================================================
PROFILE_2COL_V2_SELF_X0=0.30
PROFILE_2COL_V2_SELF_X1=0.595
PROFILE_2COL_V2_SELF_XMIN_LO=0.335
PROFILE_2COL_V2_SELF_XMIN_HI=0.555
PROFILE_2COL_V2_MANAGER_X0=0.60
PROFILE_2COL_V2_MANAGER_X1=0.995
PROFILE_2COL_V2_MANAGER_XMIN=0.61
# Body-indent threshold (x beyond body margin => new list item). Same value as
# the default profile's INDENT constant; ported for reference in case the two
# profiles diverge later.
PROFILE_2COL_V2_INDENT=0.012
# Rating-crop vertical band, relative to the heading's y (top, bottom). Only
# meaningful if a future rating-field crop feature is added to this tool —
# extract_section.py has no rating-crop feature today.
PROFILE_2COL_V2_RATING_CROP_Y_TOP=-0.006
PROFILE_2COL_V2_RATING_CROP_Y_BOTTOM=0.034
