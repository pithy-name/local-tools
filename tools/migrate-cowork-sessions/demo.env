# Copy this file to .env (same directory) and fill in YOUR values.
#   cp demo.env .env
# .env is gitignored; demo.env is the shared template.

# REQUIRED. Your Cowork workspace. TWO accepted forms — pick ONE:
#   - Relative: "<outer>/<inner>" (two nested UUID dir names) under
#       ~/Library/Application Support/Claude/local-agent-mode-sessions/
#       e.g.   COWORK_WORKSPACE=abc12345-aaaa-.../def67890-bbbb-...
#   - Absolute: the full path to that same <outer>/<inner> dir
#       e.g.   COWORK_WORKSPACE=~/Library/Application Support/Claude/local-agent-mode-sessions/abc12345-aaaa-.../def67890-bbbb-...
# Do NOT backslash-escape spaces here — the .env parser handles the path natively.
# <outer> = your organization ID; <inner> = your account ID within it. Find them:
#   ls ~/Library/Application\ Support/Claude/local-agent-mode-sessions/   -> <outer> (a UUID dir)
#   ls ~/Library/Application\ Support/Claude/local-agent-mode-sessions/<outer>/   -> <inner> (a UUID dir)
# If you see MORE THAN ONE UUID at either level (multiple orgs/accounts), you have
# multiple Cowork logins — set each <outer>/<inner> combination in turn and run
# `--list` until the spaces shown are the ones you expect.
COWORK_WORKSPACE=<outer-uuid>/<inner-uuid>

# OPTIONAL. Default Cowork space to migrate (name or UUID). Override at runtime with --space.
# Leave blank: running without --space then LISTS the available spaces (same as --list) —
# pick one from that table and re-run with --space "<name>". (There is no interactive prompt.)
COWORK_SPACE=

# OPTIONAL. Default Claude Code project dir to copy into. Override with --target.
# For a one-time migration, prefer leaving this blank and passing --target explicitly,
# so a later migration can't accidentally copy into the wrong project.
COWORK_TARGET=
